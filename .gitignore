# Godot 4.6 C# 项目通用 .gitignore
# =================================

# --- Godot 编辑器缓存（自动生成，不应提交） ---
# 如 uid 缓存，项目图标使用 uid 路径时，需要打开一次项目，建立 uid 缓存后才能显示（项目列表中），res 路径可以直接显示
.godot/

# --- 导出构建产物 ---
# 游戏导出目录，如 build/windows、build/linux、build/android
build/
# export_presets.cfg：含绝大多数导出配置，可安全提交
# .godot/export_credentials.cfg：含机密的导出选项，如密码和加密密钥，非必要无需提交

# --- C# / .NET 项目文件 ---
# Mono 运行时缓存
.mono/
# .NET SDK 缓存
.dotnet/
# NuGet 包缓存
.nuget/
# 构建输出
bin/
obj/
# 用户特定的项目配置
*.csproj.user
*.csproj.DotSettings.user
# NuGet 包文件夹
packages/

# --- IDE / 编辑器配置 / 扩展插件 ---
# VSCode
.vscode/
# C# Dev Kit 扩展：缓存语言服务数据以提高该扩展性能，可安全删除，会自动重新生成
*.lscache
# Visual Studio
.vs/
# Rider / JetBrains
.idea/
*.sln.DotSettings.user
*.sln.dotCover
*.sln.docstates

# --- 本地系统文件 ---
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
# Windows
Thumbs.db:encryptable
Desktop.ini
# Linux
.directory

# --- 翻译文件（CSV 导入产生的二进制翻译文件） ---
*.translation

# --- 其他 ---
# Godot 场景/资源备份
*.tscn.old
*.scn.old
*.res.old
# 日志
export.log
*.log
# 临时文件
*~
*.tmp
*.swp
*.swo
